@echo off\nREM ============================================================\nREM 台灣賓果應用 - 一鍵設置腳本（Windows）\nREM ============================================================\nREM 使用方式: scripts\\setup.bat\n\nsetlocal enabledelayedexpansion\n\necho.\necho ============================================================\necho   台灣賓果應用 - 一鍵設置\necho ============================================================\necho.\n\nREM 檢查 Node.js\necho [1/6] 檢查 Node.js 版本...\nnode -v >nul 2>&1\nif errorlevel 1 (\n    echo ❌ Node.js 未安裝。請先安裝 Node.js 18.x 或更高版本\n    echo 訪問: https://nodejs.org/\n    pause\n    exit /b 1\n)\nfor /f \"tokens=*\" %%i in ('node -v') do set NODE_VERSION=%%i\necho ✅ Node.js %NODE_VERSION%\n\nREM 檢查 pnpm\necho [2/6] 檢查 pnpm...\npnpm -v >nul 2>&1\nif errorlevel 1 (\n    echo ⚠️  pnpm 未安裝，正在安裝...\n    call npm install -g pnpm\n)\nfor /f \"tokens=*\" %%i in ('pnpm -v') do set PNPM_VERSION=%%i\necho ✅ pnpm %PNPM_VERSION%\n\nREM 安裝依賴\necho [3/6] 安裝項目依賴...\ncall pnpm install\nif errorlevel 1 (\n    echo ❌ 依賴安裝失敗\n    pause\n    exit /b 1\n)\necho ✅ 依賴安裝完成\n\nREM 檢查環境變數\necho [4/6] 檢查環境變數...\nif not exist \".env.local\" (\n    echo ⚠️  .env.local 不存在，正在創建...\n    if exist \".env.example\" (\n        copy .env.example .env.local\n        echo ⚠️  請編輯 .env.local 填入必要的環境變數\n        echo    必需變數: DATABASE_URL, VITE_APP_ID, JWT_SECRET\n    ) else (\n        echo ❌ .env.example 文件不存在\n        pause\n        exit /b 1\n    )\n) else (\n    echo ✅ .env.local 已存在\n)\n\nREM 初始化數據庫\necho [5/6] 初始化數據庫...\nfindstr /M \"DATABASE_URL\" .env.local >nul 2>&1\nif not errorlevel 1 (\n    echo    生成遷移文件...\n    call pnpm run db:generate 2>nul || echo    跳過遷移生成\n    \n    echo    執行數據庫遷移...\n    call pnpm run db:migrate 2>nul || echo    跳過數據庫遷移\n    \n    echo ✅ 數據庫初始化完成\n) else (\n    echo ⚠️  DATABASE_URL 未配置，跳過數據庫初始化\n)\n\nREM 構建應用\necho [6/6] 構建應用...\ncall pnpm run build 2>nul || echo    跳過構建\necho ✅ 構建完成\n\necho.\necho ============================================================\necho   ✅ 設置完成！\necho ============================================================\necho.\necho 下一步:\necho   開發模式:  pnpm run dev\necho   生產模式:  pnpm run build ^&^& pnpm run start\necho.\necho 文檔:\necho   部署指南:  type DEPLOYMENT_GUIDE.md\necho   項目說明:  type README.md\necho.\npause\n"
